# SeixasTec — Gestão Total :: EDGE (uma cópia por loja)
# Copie para .env.edge e ajuste. Usado por docker-compose.edge.yml:
#   docker compose -p seixastec_edge -f docker-compose.edge.yml --env-file .env.edge up -d

# --- Banco local da loja ---
POSTGRES_USER=cpvarejo
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=cpvarejo

# --- Segurança ---
# Gere com: openssl rand -hex 32 (pode ser diferente do da central).
JWT_SECRET=troque-este-segredo

# --- Identidade da loja e sync com a central (obrigatórios) ---
# LOJA_ID: id da loja no admin (Lojas & PDVs). EDGE_SYNC_TOKEN: gerado no admin
# (aparece uma única vez). CENTRAL_URL: domínio/IP da VPS, idealmente https.
LOJA_ID=
EDGE_SYNC_TOKEN=
CENTRAL_URL=https://central.exemplo.com

# URL do backend do edge NA LAN, usada no build do app de PDV.
EDGE_PUBLIC_URL=http://192.168.0.10:4001

# --- Fiscal (NFC-e/NF-e), opcional ---
# FISCAL_HABILITADO=true
# FISCAL_CSC=
# FISCAL_ID_CSC=

# --- Portas (opcionais) ---
# EDGE_DB_PORT=5433
# EDGE_BACKEND_PORT=4001
# PDV_PORT=8090

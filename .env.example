# SeixasTec — Gestão Total
# Copie para .env e ajuste. Usado por docker-compose.yml (nó único, dev) e
# docker-compose.central.yml (central na VPS).

# --- Banco ---
POSTGRES_USER=cpvarejo
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=cpvarejo

# --- Segurança ---
# OBRIGATÓRIO em produção: o backend NÃO SOBE com o valor placeholder.
# Gere com: openssl rand -hex 32
JWT_SECRET=troque-este-segredo

# CORS: allowlist de origens do admin/PDV, separadas por vírgula.
# Vazio = aberto (só recomendado em dev).
# CORS_ORIGINS=https://admin.exemplo.com,https://pdv.exemplo.com

# --- Central (docker-compose.central.yml) ---
# URL pública da API central (usada no build do admin).
CENTRAL_PUBLIC_URL=http://localhost:4000
# Token de sync da loja Matriz (semeado como EdgeNode) — use o mesmo no edge da Matriz.
MATRIZ_EDGE_TOKEN=edge-matriz-dev-token

# --- Nó único (docker-compose.yml, dev) ---
VITE_API_URL=http://localhost:4000

# --- Portas (opcionais) ---
# DB_PORT=5432
# BACKEND_PORT=4000
# FRONTEND_PORT=8080
# PDV_PORT=8090

# --- Backup ---
# BACKUP_CRON=0 3 * * *
# RCLONE_REMOTE=cloud:cpvarejo-backups
# BACKUP_RETENTION_DAYS=14
